# --- Nina blog publishing API ---

# Secret bearer token that Nina's n8n workflow must send when POSTing a post to
# /api/posts. Generate a long random value (e.g. `openssl rand -hex 32`) and set
# the SAME value here and in n8n's credentials + your Vercel project env vars.
NINA_PUBLISH_TOKEN=replace-with-a-long-random-secret

# --- Blog reader ---

# Base URL the front-end reads blog content from. Leave blank to read from this
# same app's own /api routes (default, recommended for the test site). Point it
# at an external Nina API when you want the reader to hit a different service.
# Example: https://api.trynina.co
NEXT_PUBLIC_NINA_API_URL=
